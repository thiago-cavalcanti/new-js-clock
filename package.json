{
  "name": "new-js-clock",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.3",
  "description": "A modern TypeScript clock library with countdown support - jQuery-free rewrite of JS-Clock",
  "homepage": "https://www.tcpweb.com.br/new-js-clock/",
  "repository": {
    "type": "git",
    "url": "https://github.com/thiago-cavalcanti/new-js-clock.git"
  },
  "bugs": {
    "url": "https://github.com/thiago-cavalcanti/new-js-clock/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "unpkg": "dist/new-js-clock.min.js",
  "jsdelivr": "dist/new-js-clock.min.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./iife": "./dist/new-js-clock.js",
    "./iife.min": "./dist/new-js-clock.min.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsc && node scripts/build-cjs.cjs && node scripts/build-iife.cjs && node scripts/sync-docs-dist.cjs",
    "build:esm": "tsc",
    "build:cjs": "node scripts/build-cjs.cjs",
    "build:iife": "node scripts/build-iife.cjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "e2e:background": "node tests/e2e/background-behavior.cjs",
    "e2e:background:all-browsers": "node scripts/run-e2e-all-browsers.cjs tests/e2e/background-behavior.cjs",
    "e2e:docker": "node scripts/run-e2e-docker.cjs tests/e2e/background-behavior.cjs",
    "check:pack": "node scripts/check-pack-contents.cjs",
    "dev": "tsc --watch",
    "prepack": "npm run build"
  },
  "keywords": [
    "clock",
    "timer",
    "countdown",
    "typescript",
    "javascript",
    "stopwatch",
    "timezone",
    "time",
    "esm",
    "iife",
    "vanilla-js"
  ],
  "author": "tcpweb",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "./dist/new-js-clock.js",
    "./dist/new-js-clock.min.js"
  ],
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "selenium-webdriver": "^4.41.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
